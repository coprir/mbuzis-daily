# URL of the Mbuzis Daily realtime (Socket.IO) server.
# Leave unset to run the web app in self-contained DEMO mode (client-side
# simulation, no backend needed). Set it to enable real presence, chat,
# moderation and WebRTC peer video.
#
#   local dev:   http://localhost:4000
#   production:  https://your-realtime-server.onrender.com
NEXT_PUBLIC_SOCKET_URL=

# Optional TURN server for reliable WebRTC video across strict/symmetric NATs.
# If unset, a free public TURN (OpenRelay) is used as a fallback.
# Comma-separate multiple URLs.
NEXT_PUBLIC_TURN_URL=
NEXT_PUBLIC_TURN_USER=
NEXT_PUBLIC_TURN_PASS=
