# Port the realtime server listens on
PORT=4000
# Allowed browser origin for CORS (your web app URL). Use * for local dev.
CLIENT_ORIGIN=http://localhost:3800

# Shared admin code — users who enter it on the join screen become admins
# (capped at 3 active admins). Change this to your own secret.
ADMIN_CODE=mbuzi-admin-2026
# SEPARATE super-admin code — makes you the OWNER / super-admin: uncapped,
# undemotable, full control. Keep this private to yourself.
SUPER_ADMIN_CODE=mbuzi-super-2026
# Optional: this username auto-becomes a super-admin (no code needed).
OWNER_USERNAME=

# --- Email notifications (who joined + session-log digests) ---
# Any SMTP provider works. Gmail example (create an "App Password" first):
#   SMTP_URL=smtps://you%40gmail.com:your-app-password@smtp.gmail.com:465
SMTP_URL=
# Where notifications are sent (defaults to the project owner's email).
REPORT_EMAIL=nawmankipkorir@gmail.com
# Optional "From" header.
MAIL_FROM=Mbuzis Daily <no-reply@mbuzisdaily.app>
# Optional: also email a full log digest every N minutes (0 = off).
DIGEST_MINUTES=0
